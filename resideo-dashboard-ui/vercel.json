{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://resideo-dashboard.onrender.com/api/v1",
    "VITE_WS_URL": "wss://resideo-dashboard.onrender.com/ws"
  }
}
